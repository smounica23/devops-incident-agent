# App
APP_ENV=development
SECRET_KEY=change-me

# PostgreSQL
DATABASE_URL=postgresql://admin:admin123@postgres:5432/incidents

# Redis
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1

# Claude API
ANTHROPIC_API_KEY=your-anthropic-api-key

# LangSmith
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=your-langsmith-api-key
LANGCHAIN_PROJECT=devops-incident-agent
LANGCHAIN_ENDPOINT=https://apac.api.smith.langchain.com

# GitHub
GITHUB_TOKEN=your-github-token
GITHUB_REPO_OWNER=your-github-username
GITHUB_TARGET_REPO=payment-service-demo
GITHUB_MCP_URL=https://api.github.com/mcp/

# Atlassian
ATLASSIAN_URL=https://yoursite.atlassian.net
ATLASSIAN_EMAIL=your-email
ATLASSIAN_API_TOKEN=your-atlassian-token
CONFLUENCE_SPACE_KEY=Incidents

# Teams
TEAMS_WEBHOOK_URL=your-teams-webhook-url

# Elasticsearch
ELASTICSEARCH_URL=http://elasticsearch:9200

# HITL timeouts (seconds)
HITL_TIMEOUT_P1=900
HITL_TIMEOUT_P2=1800
HITL_TIMEOUT_P3=7200
